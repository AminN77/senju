# API
API_PORT=8080
# Gin: debug | release | test (case-insensitive). Empty = release for bare binary; Docker Compose defaults to debug.
GIN_MODE=debug
# Log level for zerolog: trace, debug, info, warn, error, fatal, panic, disabled
LOG_LEVEL=info
# Graceful shutdown deadline after SIGINT/SIGTERM (Go duration, e.g. 30s, 1m)
SHUTDOWN_TIMEOUT=30s

# PostgreSQL (host is "postgres" inside Docker Compose; "localhost" when running API on host)
POSTGRES_HOST=localhost
POSTGRES_DB=senju
POSTGRES_USER=senju
POSTGRES_PASSWORD=senju_dev_password
POSTGRES_PORT=5432

# Readiness probes (URLs match docker-compose service names when running in Compose)
CLICKHOUSE_HTTP_URL=http://localhost:8123
MINIO_HEALTH_URL=http://localhost:9001/minio/health/live
NATS_ADDR=localhost:4222

# ClickHouse
CLICKHOUSE_DB=senju
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=senju_dev_password
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9001
MINIO_CONSOLE_PORT=9002

# NATS
NATS_PORT=4222
