# API
API_PORT=8080
# Gin: debug | release | test (case-insensitive). Empty = release for bare binary; Docker Compose defaults to debug.
GIN_MODE=debug
# Log level for zerolog: trace, debug, info, warn, error, fatal, panic, disabled
LOG_LEVEL=info
# Graceful shutdown deadline after SIGINT/SIGTERM (Go duration, e.g. 30s, 1m)
SHUTDOWN_TIMEOUT=30s

# PostgreSQL (host is "postgres" inside Docker Compose; "localhost" when running API on host)
POSTGRES_HOST=localhost
POSTGRES_DB=senju
POSTGRES_USER=senju
POSTGRES_PASSWORD=senju_dev_password
POSTGRES_PORT=5432

# Readiness probes (URLs match docker-compose service names when running in Compose)
CLICKHOUSE_HTTP_URL=http://localhost:8123
MINIO_HEALTH_URL=http://localhost:9001/minio/health/live
NATS_ADDR=localhost:4222

# ClickHouse
CLICKHOUSE_DB=senju
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=senju_dev_password
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9001
MINIO_CONSOLE_PORT=9002

# S3-compatible API (multipart presigned uploads; Issue #7). Uses MINIO_ROOT_* when S3_ACCESS_KEY unset.
# From the host, point at the mapped API port (see MINIO_API_PORT). Inside Docker Compose, use http://minio:9000.
S3_ENDPOINT=http://localhost:9001
S3_BUCKET=senju-uploads
S3_REGION=us-east-1
# Path-style is required for MinIO with custom endpoints (default true).
S3_USE_PATH_STYLE=true

# NATS
NATS_PORT=4222

# Queue behavior (Issue #9)
QUEUE_STREAM_NAME=jobs_stream
QUEUE_SUBJECT=jobs.execute
QUEUE_DEAD_LETTER_SUBJECT=jobs.dead_letter
QUEUE_CONSUMER_NAME=jobs_worker
QUEUE_MAX_RETRIES=3
QUEUE_BACKOFF_BASE=1s
