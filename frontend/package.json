{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "shadcn": "shadcn",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:contrast": "vitest run src/styles/contrast.test.ts",
    "e2e": "playwright test",
    "e2e:ci": "playwright test tests/e2e --project=chromium",
    "a11y": "playwright test tests/a11y --project=chromium",
    "test:bundle-budget": "node ./scripts/check-bundle-budget.mjs",
    "test:changed": "node ./scripts/test-changed.mjs",
    "hooks:install": "node ./scripts/install-git-hooks.mjs",
    "hooks:precommit": "node ./scripts/run-frontend-precommit.mjs",
    "codegen": "openapi-typescript ../backend/openapi/openapi.yaml -o src/lib/api/generated/schema.ts",
    "codegen:check": "pnpm codegen && git diff --exit-code -- src/lib/api/generated/schema.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0 --fix",
      "prettier --write"
    ],
    "*.{css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-primitive": "^2.1.4",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "openapi-fetch": "^0.17.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.74.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-themes": "^10.3.5",
    "@storybook/nextjs": "^10.3.5",
    "@storybook/react": "10.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "culori": "^4.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "shadcn": "^4.4.0",
    "storybook": "^10.3.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
